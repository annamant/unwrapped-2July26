{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm install --include=dev && tsc"
  },
  "deploy": {
    "preDeployCommand": "node -e \"console.log('drizzle push skipped — schema applied manually')\"",
    "startCommand": "node dist/index.js",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
